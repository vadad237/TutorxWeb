@model ImportPreviewVm
@{ ViewData["Title"] = "Náhľad importu"; }

<h2>Náhľad importu &mdash; @Model.GroupName</h2>
<hr />

@{
    var validCount = Model.Rows.Count(r => r.Status == "Valid");
    var errCount = Model.Rows.Count(r => r.Status == "Error");
    var cardErrCount = Model.Rows.Count(r => r.Status == "Error" && r.ErrorMessage != null && r.ErrorMessage.StartsWith("Číslo karty"));
}

<div class="alert alert-info">
    <strong>@validCount</strong> platných, <strong>@errCount</strong> chybných riadkov.
    @if (cardErrCount > 0)
    {
        <span id="cardErrBadge" class="ms-2 badge bg-danger"><i class="bi bi-credit-card me-1"></i>@cardErrCount konflikt@(cardErrCount == 1 ? "" : "ov") čísla karty</span>
    }
</div>

<form asp-action="ImportConfirm" method="post">
    <input type="hidden" name="GroupId" value="@Model.GroupId" />

    <div class="card mb-3">
        <div class="card-body">
            <strong>Stĺpce na import:</strong>
            <div class="d-flex gap-4 mt-2">
                <div class="form-check">
                    <input type="checkbox" name="ImportEmail" value="true" id="colEmail"
                           class="form-check-input col-toggle" data-col="col-email" checked />
                    <input type="hidden" name="ImportEmail" value="false" />
                    <label class="form-check-label" for="colEmail">Email</label>
                </div>
                @* <div class="form-check">
                    <input type="checkbox" name="ImportCardNumber" value="true" id="colCardNumber"
                           class="form-check-input col-toggle" data-col="col-cardnumber" checked />
                    <input type="hidden" name="ImportCardNumber" value="false" />
                    <label class="form-check-label" for="colCardNumber">Číslo karty</label>
                </div> *@
                <div class="form-check">
                    <input type="checkbox" name="ImportYear" value="true" id="colYear"
                           class="form-check-input col-toggle" data-col="col-year" checked />
                    <input type="hidden" name="ImportYear" value="false" />
                    <label class="form-check-label" for="colYear">Ročník</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" name="ImportGroupNumber" value="true" id="colGroupNumber"
                           class="form-check-input col-toggle" data-col="col-groupnumber" checked />
                    <input type="hidden" name="ImportGroupNumber" value="false" />
                    <label class="form-check-label" for="colGroupNumber">Krúžok</label>
                </div>
            </div>
        </div>
    </div>

    <table id="importPreviewTable" class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Importovať?</th>
                <th data-sort="text">Meno<span class="sort-icon"></span></th>
                <th data-sort="text">Priezvisko<span class="sort-icon"></span></th>
                <th class="col-email" data-sort="text">Email<span class="sort-icon"></span></th>
                <th class="col-cardnumber" data-sort="text">Číslo karty<span class="sort-icon"></span></th>
                <th class="col-year" data-sort="num">Ročník<span class="sort-icon"></span></th>
                <th class="col-groupnumber" data-sort="text">Krúžok<span class="sort-icon"></span></th>
                <th data-sort="text">Stav<span class="sort-icon"></span></th>
                <th data-sort="text">Poznámka<span class="sort-icon"></span></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Rows.Count; i++)
            {
                var row = Model.Rows[i];
                <tr class="@(row.Status == "Error" ? "table-danger" : "")"
                    @(row.Status == "Error" && row.ErrorMessage != null && row.ErrorMessage.StartsWith("Číslo karty") ? Html.Raw("data-card-err=\"true\"") : Html.Raw(""))>
                    <td>
                        <input type="hidden" name="Rows[@i].FirstName" value="@row.FirstName" />
                        <input type="hidden" name="Rows[@i].LastName" value="@row.LastName" />
                        <input type="hidden" name="Rows[@i].Email" value="@row.Email" />
                        <input type="hidden" name="Rows[@i].CardNumber" value="@row.CardNumber" />
                        <input type="hidden" name="Rows[@i].Year" value="@row.Year" />
                        <input type="hidden" name="Rows[@i].GroupNumber" value="@row.GroupNumber" />
                        <input type="hidden" name="Rows[@i].Status" value="@row.Status" />
                        @if (row.Status != "Error")
                        {
                            <input type="checkbox" name="Rows[@i].Selected" value="true"
                                   class="form-check-input"
                                   @(row.Selected ? "checked" : "") />
                            <input type="hidden" name="Rows[@i].Selected" value="false" />
                        }
                        else
                        {
                            <span class="text-danger">-</span>
                        }
                    </td>
                    <td>@row.FirstName</td>
                    <td>@row.LastName</td>
                    <td class="col-email">@(row.Email ?? "-")</td>
                    <td class="col-cardnumber @(row.Status == "Error" && row.ErrorMessage != null && row.ErrorMessage.StartsWith("Číslo karty") ? "text-danger fw-semibold" : "")">
                        @(row.CardNumber ?? "-")
                    </td>
                    <td class="col-year">@(row.Year.HasValue ? row.Year.Value.ToString() : "-")</td>
                    <td class="col-groupnumber">@(row.GroupNumber ?? "-")</td>
                    <td>
                        @if (row.Status == "Valid") { <span class="badge bg-success">Platný</span> }
                        else { <span class="badge bg-danger">Chyba</span> }
                    </td>
                    <td>@(row.ErrorMessage ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Potvrdiť import</button>
    <a asp-action="Import" asp-route-groupId="@Model.GroupId" class="btn btn-secondary">Zrušiť</a>
</form>

@* Scripts loaded from site.js *@
