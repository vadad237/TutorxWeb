@model EvaluationEditVm
@{ ViewData["Title"] = "Upraviť hodnotenie"; }

<h2>Upraviť hodnotenie</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="StudentId" />
            <input type="hidden" asp-for="TaskItemId" />
            <input type="hidden" asp-for="StudentName" />
            <input type="hidden" asp-for="TaskName" />
            <input type="hidden" asp-for="MaxScore" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Študent</label>
                <input type="text" class="form-control" value="@Model.StudentName" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Úloha</label>
                <input type="text" class="form-control" value="@Model.TaskName" disabled />
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label">Skóre *</label>
                <input asp-for="Score" class="form-control" type="number" step="0.01" required
                       max="@(Model.MaxScore.HasValue ? Model.MaxScore.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : null)" />
                @if (Model.MaxScore.HasValue)
                {
                    <div class="form-text">Maximálne skóre: <strong>@Model.MaxScore.Value</strong></div>
                }
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Comment" class="form-label">Komentár</label>
                <textarea asp-for="Comment" class="form-control" rows="3" maxlength="500"></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Uložiť</button>
            <a asp-action="Index" class="btn btn-secondary">Zrušiť</a>
        </form>
    </div>
</div>
