@model LoginViewModel
@{
    ViewData["Title"] = "Prihlásenie";
    Layout = null;
}

<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prihlásenie - TutorX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f5f5f5; display: flex; align-items: center; min-height: 100vh; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body p-5">
                        <h3 class="card-title text-center mb-4">Prihlásenie do TutorX</h3>

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                            <div class="mb-3">
                                <label asp-for="UserName" class="form-label">Používateľské meno</label>
                                <input asp-for="UserName" class="form-control" autofocus required />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Heslo</label>
                                <input asp-for="Password" class="form-control" required />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="mb-3 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">Zapamätať si ma</label>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Prihlásiť</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
