@{
    var activeGroupId = Context.Session.GetActiveGroup();
    var activeGroupName = activeGroupId.HasValue ? ViewData["ActiveGroupName"]?.ToString() ?? "Group" : null;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string NavClass(string controller, string? action = null)
    {
        var controllerMatch = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        var actionMatch = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return controllerMatch && actionMatch ? "nav-link text-white fw-semibold active-nav" : "nav-link text-white";
    }
}
<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TutorX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar" class="bg-dark text-white">
        <div class="sidebar-header p-3 border-bottom border-secondary">
            <h5 class="mb-0">TutorX</h5>
        </div>
        <ul class="nav flex-column p-2">
            <li class="nav-item">
                <a class="@NavClass("Groups")" asp-controller="Groups" asp-action="Index">
                    <i class="bi bi-collection me-2"></i>Skupiny
                </a>
            </li>
        </ul>
        <hr class="border-secondary mx-2 my-1" />
        <ul class="nav flex-column p-2">
            <li class="nav-item">
                <a class="@NavClass("Students")" asp-controller="Students" asp-action="Index">
                    <i class="bi bi-people me-2"></i>Študenti
                </a>
            </li>
            <li class="nav-item">
                <a class="@NavClass("Activities")" asp-controller="Activities" asp-action="Index">
                    <i class="bi bi-clipboard-check me-2"></i>Aktivity
                </a>
            </li>
            <li class="nav-item">
                <a class="@NavClass("Draw")" asp-controller="Draw" asp-action="Index">
                    <i class="bi bi-shuffle me-2"></i>Žrebovanie
                </a>
            </li>
            <li class="nav-item">
                <a class="@NavClass("Attendance")" asp-controller="Attendance" asp-action="Record">
                    <i class="bi bi-calendar-check me-2"></i>Dochádzka
                </a>
            </li>
            <li class="nav-item">
                <a class="@NavClass("Evaluations")" asp-controller="Evaluations" asp-action="Index">
                    <i class="bi bi-graph-up me-2"></i>Hodnotenia
                </a>
            </li>
        </ul>
        <hr class="border-secondary mx-2 my-1" />
        <ul class="nav flex-column p-2">
            <li class="nav-item">
                <a class="@NavClass("CustomExport")" asp-controller="CustomExport" asp-action="Index">
                    <i class="bi bi-download me-2"></i>Vlastný export
                </a>
            </li>
        </ul>
    </nav>

    <!-- Page content -->
    <div id="content">
        <!-- Top navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-3">
            <button class="btn btn-dark d-lg-none me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                <i class="bi bi-list"></i>
            </button>

            <div class="d-flex align-items-center ms-auto">
                <!-- Active Group Dropdown -->
                @if (ViewBag.AllGroups != null)
                {
                    var groups = (IEnumerable<dynamic>)ViewBag.AllGroups;
                    <div class="d-flex align-items-center me-3">
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            @if (activeGroupId.HasValue)
                            {
                                <span>@activeGroupName</span>
                            }
                            else
                            {
                                <span class="text-warning">Vybrať skupinu</span>
                            }
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @foreach (var g in groups)
                            {
                                <li>
                                    <form asp-controller="Groups" asp-action="SetActive" asp-route-id="@g.Id" method="post">
                                        <button type="submit" class="dropdown-item @(activeGroupId == (int)g.Id ? "active" : "")">@g.Name</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                    <a asp-controller="Groups" asp-action="Create" class="btn btn-primary btn-sm ms-1" title="Nová skupina">
                        <i class="bi bi-plus-lg"></i>
                    </a>
                    </div>
                }

                <!-- Logout -->
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Odhlásiť
                    </button>
                </form>
            </div>
        </nav>

        <!-- Flash messages -->
        <div class="container-fluid mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>

        <!-- Main content -->
        <main class="container-fluid p-4">
            @RenderBody()
        </main>
    </div>

    <!-- Offcanvas sidebar for mobile -->
    <div class="offcanvas offcanvas-start bg-dark text-white" id="sidebarOffcanvas">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title">TutorX</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="nav flex-column p-2">
                <li class="nav-item">
                    <a class="@NavClass("Groups")" asp-controller="Groups" asp-action="Index">
                        <i class="bi bi-collection me-2"></i>Skupiny
                    </a>
                </li>
            </ul>
            <hr class="border-secondary mx-2 my-1" />
            <ul class="nav flex-column p-2">
                <li class="nav-item">
                    <a class="@NavClass("Students")" asp-controller="Students" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Študenti
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("Activities")" asp-controller="Activities" asp-action="Index">
                        <i class="bi bi-clipboard-check me-2"></i>Aktivity
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("Draw")" asp-controller="Draw" asp-action="Index">
                        <i class="bi bi-shuffle me-2"></i>Žrebovanie
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("Attendance")" asp-controller="Attendance" asp-action="Record">
                        <i class="bi bi-calendar-check me-2"></i>Dochádzka
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("Evaluations")" asp-controller="Evaluations" asp-action="Index">
                        <i class="bi bi-graph-up me-2"></i>Hodnotenia
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Confirm Modal Template -->
    <div class="modal fade" id="confirmModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmModalTitle">Potvrdiť akciu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="confirmModalBody">
                    Ste si istý?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušiť</button>
                    <button type="button" class="btn btn-danger" id="confirmModalAction">Potvrdiť</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast notification container -->
    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
