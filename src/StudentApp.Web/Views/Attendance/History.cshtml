@model AttendanceHistoryVm
@{ ViewData["Title"] = "História dochádzky"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>História dochádzky &mdash; @Model.GroupName</h2>
    <div>
        <a asp-action="Record" asp-route-groupId="@Model.GroupId" class="btn btn-primary btn-sm">Záznam</a>
        <a asp-action="Summary" asp-route-groupId="@Model.GroupId" class="btn btn-outline-info btn-sm">Súhrn</a>
    </div>
</div>

@if (Model.Dates.Any())
{
    <style>
        .att-wrap {
            max-height: 75vh;
            overflow: auto;
        }
        .att-wrap table {
            border-collapse: separate;
            border-spacing: 0;
        }
        /* Sticky header row */
        .att-wrap thead tr th {
            position: sticky;
            top: 0;
            z-index: 3;
        }
        /* Sticky first column */
        .att-wrap thead tr th:first-child,
        .att-wrap tbody tr td:first-child {
            position: sticky;
            left: 0;
            z-index: 2;
            background: #fff;
        }
        /* Header corner cell needs highest z-index */
        .att-wrap thead tr th:first-child {
            z-index: 4;
            background: #212529;
        }
        /* Restore border on sticky column */
        .att-wrap tbody tr td:first-child {
            border-right: 1px solid #dee2e6;
        }
    </style>
    <div class="table-responsive att-wrap">
        <table class="table table-bordered table-sm">
            <thead class="table-dark">
                <tr>
                    <th>Študent</th>
                    @foreach (var d in Model.Dates)
                    {
                        <th class="text-center" style="min-width:60px;">@d.ToString("dd.MM")</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Students)
                {
                    <tr>
                        <td>@s.FullName</td>
                        @foreach (var d in Model.Dates)
                        {
                            var key = (s.Id, d);
                            <td class="text-center">
                                @if (Model.StatusMap.TryGetValue(key, out var status))
                                {
                                    @if (status == AttendanceStatus.Present) { <span class="badge bg-success">P</span> }
                                    else if (status == AttendanceStatus.Absent) { <span class="badge bg-danger">A</span> }
                                    else { <span class="badge bg-warning text-dark">E</span> }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">-</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">Žiadne záznamy o dochádzke.</div>
}
