@model ActivityDetailsVm
@{
    ViewData["Title"] = Model.Name;
    var allStudents = (List<StudentSummaryVm>)ViewBag.AllStudents;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Upraviť</a>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }
        <p><strong>Skupina:</strong> @Model.GroupName</p>
    </div>
</div>

<!-- Assigned Students Section -->
<div class="card mb-3">
    <div class="card-body">
        <h5>Priradení študenti</h5>
        <div class="badge-area mb-2" id="activity-badge-area">
            @if (Model.AssignedStudents.Any())
            {
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var s in Model.AssignedStudents)
                    {
                        <span class="badge bg-info text-dark">@s.FullName</span>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small mb-0">Žiadni študenti zatiaľ neboli priradení.</p>
            }
        </div>
        <form class="activity-assign-form" id="activityAssignForm" data-activity-id="@Model.Id">
            @Html.AntiForgeryToken()
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    <i class="bi bi-people me-1"></i>Vybrať študentov
                </button>
                <ul class="dropdown-menu p-2" style="min-width:230px; max-height:260px; overflow-y:auto">
                    @foreach (var student in allStudents)
                    {
                        var isChecked = Model.AssignedStudents.Any(a => a.StudentId == student.Id);
                        <li>
                            <label class="dropdown-item d-flex align-items-center gap-2 py-1 px-2" style="cursor:pointer">
                                @if (isChecked)
                                {
                                    <input class="form-check-input mt-0 flex-shrink-0" type="checkbox"
                                           name="studentIds" value="@student.Id" data-name="@student.FullName" checked />
                                }
                                else
                                {
                                    <input class="form-check-input mt-0 flex-shrink-0" type="checkbox"
                                           name="studentIds" value="@student.Id" data-name="@student.FullName" />
                                }
                                @student.FullName
                            </label>
                        </li>
                    }
                </ul>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════
     TASKS SECTION
     ══════════════════════════════════════════════════════ -->
<div class="card mb-3">
    <div class="card-body">
        <h5>Pridať úlohu</h5>
        <div class="input-group">
            <input type="text" id="taskTitle" class="form-control" placeholder="Názov úlohy..." maxlength="300" />
            <button type="button" id="addTaskBtn" class="btn btn-primary" data-activity-id="@Model.Id">Pridať úlohu</button>
        </div>
    </div>
</div>

<h4>Úlohy (@Model.Tasks.Count)</h4>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info">Žiadne úlohy. Pridajte úlohy vyššie.</div>
}
else
{
    <table class="table table-striped align-middle mb-4" id="taskTable">
        <thead class="table-dark">
            <tr>
                <th>Úloha</th>
                <th style="width:100px">Akcie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Tasks)
            {
                <tr>
                    <td>@t.Title</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-danger btn-delete-task" data-id="@t.TaskId">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- ══════════════════════════════════════════════════════
     PRESENTATIONS SECTION
     ══════════════════════════════════════════════════════ -->
<div class="card mb-3">
    <div class="card-body">
        <h5>Pridať prezentáciu</h5>
        <div class="input-group">
            <input type="text" id="presTitle" class="form-control" placeholder="Názov prezentácie..." maxlength="300" />
            <input type="date" id="presDate" class="form-control" style="max-width:180px" />
            <button type="button" id="addPresBtn" class="btn btn-success" data-activity-id="@Model.Id">Pridať prezentáciu</button>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h4 class="mb-0">Prezentácie (@Model.Presentations.Count)</h4>
    <div id="presSelectionToolbar" class="d-flex align-items-center gap-2">
        <span id="presSelectionCount" class="text-muted small"></span>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="presDrawBtn" disabled>
            <i class="bi bi-dice-3 me-1"></i>Žrebovanie
        </button>
    </div>
</div>

@if (!Model.Presentations.Any())
{
    <div class="alert alert-info">Žiadne prezentácie. Pridajte jednu vyššie.</div>
}
else
{
    <table class="table table-striped align-middle" id="presTable">
        <thead class="table-dark">
            <tr>
                <th style="width:2.5rem">
                    <input type="checkbox" id="presSelectAll" class="form-check-input" title="Označiť všetko" />
                </th>
                <th style="width:22%">Názov</th>
                <th style="width:14%">Dátum</th>
                <th>Prezentujúci</th>
                <th>Náhradník</th>
                <th style="width:90px">Akcie</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Presentations)
        {
            <tr>
                <td>
                    <input type="checkbox" class="form-check-input pres-row-check" value="@p.TaskId" data-name="@p.Title" />
                </td>
                <td>
                    <input type="text" class="form-control form-control-sm pres-title-input"
                           data-id="@p.TaskId" value="@p.Title" maxlength="300" />
                </td>
                <td>
                    <input type="date" class="form-control form-control-sm pres-date-input"
                           data-id="@p.TaskId"
                           value="@(p.PresentationDate.HasValue ? p.PresentationDate.Value.ToString("yyyy-MM-dd") : "")" />
                </td>
                <td>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="pres-badge-area d-flex flex-wrap gap-1" id="pres-presentee-badges-@p.TaskId">
                            @if (p.PresenteeStudents.Any())
                            {
                                @foreach (var ps in p.PresenteeStudents)
                                {
                                    <span class="badge bg-primary">@ps.FullName</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">Žiadni</span>
                            }
                        </div>
                        @if (Model.AssignedStudents.Any())
                        {
                            <div class="dropdown pres-role-dropdown" data-task-id="@p.TaskId" data-role="0" data-badge-area="pres-presentee-badges-@p.TaskId">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                    <i class="bi bi-people"></i>
                                </button>
                                <ul class="dropdown-menu p-2" style="min-width:220px;max-height:250px;overflow-y:auto">
                                    @foreach (var s in Model.AssignedStudents)
                                    {
                                        var isPresentee = p.PresenteeStudents.Any(ps => ps.StudentId == s.StudentId);
                                        <li>
                                            <label class="dropdown-item d-flex align-items-center gap-2 py-1 px-2" style="cursor:pointer">
                                                <input class="form-check-input mt-0 flex-shrink-0 pres-student-cb"
                                                       type="checkbox" value="@s.StudentId" data-name="@s.FullName"
                                                       @(isPresentee ? "checked" : "") />
                                                @s.FullName
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </td>
                <td>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="pres-badge-area d-flex flex-wrap gap-1" id="pres-sub-badges-@p.TaskId">
                            @if (p.SubstitutionStudents.Any())
                            {
                                @foreach (var ps in p.SubstitutionStudents)
                                {
                                    <span class="badge bg-warning text-dark">@ps.FullName</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">Žiadni</span>
                            }
                        </div>
                        @if (Model.AssignedStudents.Any())
                        {
                            <div class="dropdown pres-role-dropdown" data-task-id="@p.TaskId" data-role="1" data-badge-area="pres-sub-badges-@p.TaskId">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                    <i class="bi bi-people"></i>
                                </button>
                                <ul class="dropdown-menu p-2" style="min-width:220px;max-height:250px;overflow-y:auto">
                                    @foreach (var s in Model.AssignedStudents)
                                    {
                                        var isSub = p.SubstitutionStudents.Any(ps => ps.StudentId == s.StudentId);
                                        <li>
                                            <label class="dropdown-item d-flex align-items-center gap-2 py-1 px-2" style="cursor:pointer">
                                                <input class="form-check-input mt-0 flex-shrink-0 pres-student-cb"
                                                       type="checkbox" value="@s.StudentId" data-name="@s.FullName"
                                                       @(isSub ? "checked" : "") />
                                                @s.FullName
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary btn-draw-pres"
                                data-id="@p.TaskId" data-role="0" title="Žrebovanie – prezentujúci">
                            <i class="bi bi-person-fill"></i>
                        </button>
                        <button type="button" class="btn btn-outline-warning btn-draw-pres"
                                data-id="@p.TaskId" data-role="1" title="Žrebovanie – náhradník">
                            <i class="bi bi-person-fill-up"></i>
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-draw-pres"
                                data-id="@p.TaskId" data-role="both" title="Žrebovanie – obaja">
                            <i class="bi bi-dice-3"></i>
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-delete-task" data-id="@p.TaskId"
                                title="Vymazať">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<!-- ══════════════════════════════════════════════════════
     OTHER ATTRIBUTES SECTION
     ══════════════════════════════════════════════════════ -->
<div class="d-flex align-items-center gap-2 mb-2 mt-4">
    <h4 class="mb-0">Ostatné</h4>
    <div class="input-group input-group-sm" style="max-width:260px">
        <input type="text" id="newAttrName" class="form-control" placeholder="Názov nového atribútu…" maxlength="200" />
        <button type="button" id="addAttrBtn" class="btn btn-outline-primary" data-activity-id="@Model.Id">
            <i class="bi bi-plus-lg"></i> Pridať
        </button>
    </div>
</div>

@if (!Model.AssignedStudents.Any())
{
    <div class="alert alert-info">Najskôr priraďte študentov k aktivite, aby ste mohli používať tabuľku Ostatné.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-sm align-middle" id="otherTable">
            <thead class="table-dark">
                <tr>
                    <th>Študent</th>
                    @foreach (var attr in Model.OtherAttributes)
                    {
                        <th class="text-center" style="min-width:140px" data-attr-id="@attr.AttributeId">
                            <div class="d-flex align-items-center justify-content-center gap-1">
                                <span class="attr-name-label">@attr.Name</span>
                                <button type="button" class="btn btn-sm btn-link p-0 text-white btn-manage-attr"
                                        data-attr-id="@attr.AttributeId" data-attr-name="@attr.Name"
                                        title="Spravovať stavy">
                                    <i class="bi bi-gear-fill"></i>
                                </button>
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.AssignedStudents)
                {
                    <tr data-student-id="@s.StudentId">
                        <td>@s.FullName</td>
                        @foreach (var attr in Model.OtherAttributes)
                        {
                            var val = Model.AttributeValues.FirstOrDefault(v => v.StudentId == s.StudentId && v.AttributeId == attr.AttributeId);
                            <td class="text-center" data-attr-id="@attr.AttributeId">
                                @if (!attr.Options.Any())
                                {
                                    <span class="text-muted small fst-italic">Žiadne stavy</span>
                                }
                                else
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-sm dropdown-toggle @(val?.OptionId != null ? $"btn-{val.OptionColor}" : "btn-outline-secondary")"
                                                type="button" data-bs-toggle="dropdown">
                                            @(val?.OptionName ?? "—")
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item text-muted other-value-pick"
                                                   href="#"
                                                   data-student-id="@s.StudentId"
                                                   data-attr-id="@attr.AttributeId"
                                                   data-option-id="">— Vyčistiť —</a>
                                            </li>
                                            @foreach (var opt in attr.Options)
                                            {
                                                <li>
                                                    <a class="dropdown-item other-value-pick"
                                                       href="#"
                                                       data-student-id="@s.StudentId"
                                                       data-attr-id="@attr.AttributeId"
                                                       data-option-id="@opt.OptionId"
                                                       data-option-name="@opt.Name"
                                                       data-option-color="@opt.Color">
                                                        <span class="badge bg-@opt.Color me-1">&#8203;</span>@opt.Name
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.OtherAttributes.Any())
    {
        <div class="alert alert-info">Žiadne atribúty. Pridajte jeden vyššie.</div>
    }
}

<!-- Manage States Modal -->
<div class="modal fade" id="manageStatesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Spravovať stavy</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Attribute name -->
                <div class="mb-3 d-flex gap-2 align-items-center">
                    <input type="text" id="modalAttrName" class="form-control form-control-sm" placeholder="Názov atribútu" maxlength="200" />
                    <button type="button" id="modalDeleteAttrBtn" class="btn btn-sm btn-outline-danger flex-shrink-0" title="Vymazať atribút">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <hr class="my-2" />
                <!-- States list -->
                <div id="statesList" class="mb-3"></div>
                <!-- Add state form -->
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <input type="text" id="newStateName" class="form-control form-control-sm" style="max-width:150px" placeholder="Názov stavu…" maxlength="200" />
                    <select id="newStateColor" class="form-select form-select-sm" style="max-width:130px">
                        <option value="secondary">Šedá</option>
                        <option value="primary">Modrá</option>
                        <option value="success">Zelená</option>
                        <option value="danger">Červená</option>
                        <option value="warning">Žltá</option>
                        <option value="info">Tyrkysová</option>
                        <option value="dark">Tmavá</option>
                    </select>
                    <button type="button" id="addStateBtn" class="btn btn-sm btn-primary">Pridať stav</button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušiť</button>
                <button type="button" id="modalSaveBtn" class="btn btn-primary">Uložiť</button>
            </div>
        </div>
    </div>
</div>
@* Scripts loaded from site.js *@
