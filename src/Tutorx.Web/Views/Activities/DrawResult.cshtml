@model DrawResultVm
@{
    ViewData["Title"] = "Žrebovanie – " + Model.SourceName;
    var drawnJson = System.Text.Json.JsonSerializer.Serialize(Model.DrawnStudentNames);
    var allJson   = System.Text.Json.JsonSerializer.Serialize(Model.AllStudentNames);
}

@section Styles {
    <link rel="stylesheet" href="~/css/slot-machine.css" asp-append-version="true" />
}

<div class="draw-hero">

    <!-- Header -->
    <div class="text-center">
        <h2 class="mb-0">@Model.SourceName</h2>
        <div class="d-flex justify-content-center gap-3 mt-1">
            <span class="text-muted small"><strong>Aktivita:</strong> @Model.ActivityName</span>
            <span class="badge bg-secondary align-self-center">@Model.DrawTypeName</span>
        </div>
    </div>

    <!-- Drum -->
    <div class="slot-outer">
        <div class="slot-display" id="slot-display">
            <span class="slot-name" id="slot-name">
                <span class="dot-spinner"><span></span><span></span><span></span></span>
            </span>
        </div>
    </div>

    <!-- Progress -->
    <p id="progress-label" class="text-muted"></p>

    <!-- Results -->
    <div id="results-area" class="text-center" style="min-height:60px">
        @if (Model.DrawnStudentNames.Count > 1)
        {
            <p class="text-muted small mb-2">Žrebovaní doteraz</p>
        }
        <div id="results-list" class="d-flex flex-wrap justify-content-center gap-3"></div>
    </div>

    <!-- Complete -->
    <div id="complete-section" class="text-center">
        <p class="text-success fw-semibold mb-3 fs-5">
            <i class="bi bi-check-circle-fill me-2"></i>Žrebovanie dokončené!
        </p>
        <a asp-action="Details" asp-route-id="@Model.ActivityId" class="btn btn-primary btn-lg">
            <i class="bi bi-arrow-left me-2"></i>Späť na aktivitu
        </a>
    </div>

    <div id="draw-result-data" data-drawn='@Html.Raw(drawnJson)' data-all='@Html.Raw(allJson)' style="display:none"></div>
</div>

@* Scripts loaded from site.js *@

